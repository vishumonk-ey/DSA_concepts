/**
 * @param {number[]} nums
 * @param {number} target
 * @return {number}
 */
var search = function(nums, target) {
    let indx = -1
    let left = 0 
    let right = nums.length -1 
    while( left <= right){
        let mid = Math.floor((left+right)/2)
        if(nums[mid] == target){
            indx = mid
            break
        }else if(  nums[mid] >= nums[left]) {// left half is sorted
                if( target >= nums[left] && target <= nums[mid]){
                    right = mid
                }else{
                    left = mid + 1
                }
        }else{ // right part is sorted
                if( nums[mid+1] <= target && target <= nums[right]){
                    left = mid + 1
                }else{
                    right = mid
                }
        }
    }
    return indx
};

/*  Rotated sorted Array concept -: 
    binary search -> find mid , then eliminate one half .
    but in general both the halves are sorted so we can easily eliminate one half .
    But here we cant eliminate that easily , so firstly we # identified the sorted half 
    # then find out whether it exists in the sorted half or not , if exists then eleminate the other half or if it doesnt then eliminate the sorted half.
